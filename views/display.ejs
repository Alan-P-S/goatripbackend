<!DOCTYPE html>
<html>
  <head>
    <title>Real-Time Display</title>
    <script src="/socket.io/socket.io.js"></script>
  </head>
  <body>
    <h1>Latest Received Image</h1>
    <div id="image-container">
      <p>Waiting for images...</p>
    </div>
     <h1>Camera Controller</h1>
    <!-- Button to trigger the camera -->
    <button id="captureBtn" style="padding: 10px 20px; cursor: pointer;">
        📸 Capture New Photo
    </button>
    <script>
      const socket = io();
      const container = document.getElementById("image-container");
      document.getElementById('captureBtn').addEventListener('click', () => {
            // Tell the server we want a photo
            socket.emit('trigger-camera');
      });
      socket.on("new-image", (dataUri) => {
        // Update the container with the new image
        container.innerHTML = `<img src="${dataUri}" style="max-width: 100%; border: 2px solid #333;">`;
      });
    </script>
  </body>
</html>
